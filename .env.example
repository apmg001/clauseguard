# Copy to .env and adjust per environment. All variables are optional;
# sensible defaults live in src/clauseguard/config.py.
CLAUSEGUARD_ENVIRONMENT=local
CLAUSEGUARD_LOG_LEVEL=INFO
CLAUSEGUARD_LOG_JSON=false
CLAUSEGUARD_MATCH_ACCEPT_THRESHOLD=0.75
CLAUSEGUARD_REVIEW_CONFIDENCE_THRESHOLD=0.70
CLAUSEGUARD_ARITHMETIC_TOLERANCE=0.01
